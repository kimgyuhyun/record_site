# 실제 값을 채운 뒤 이 파일을 .env 로 복사해서 사용한다 (.env 는 git 에 올리지 않는다).
# spring-dotenv 가 백엔드 실행 디렉터리(backend/)의 .env 를 읽어 application.yaml 의 ${...} 자리에 주입한다.

# Riot 개발자 포털(https://developer.riotgames.com)에서 발급. 개발용 키는 24시간마다 만료된다.
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 로컬 MySQL(docker-compose) root 비밀번호
DB_PASSWORD=1234
